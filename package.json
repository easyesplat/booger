{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "cp README.md packages/react-grab/README.md && turbo run build --filter=react-grab",
    "dev": "turbo dev --filter=react-grab",
    "test": "turbo run test --filter=react-grab",
    "typecheck": "pnpm --filter react-grab typecheck",
    "lint": "pnpm --filter react-grab lint",
    "lint:fix": "pnpm --filter react-grab lint:fix",
    "format": "oxfmt",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "oxfmt": "^0.27.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "untun": "^0.1.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {}

}
